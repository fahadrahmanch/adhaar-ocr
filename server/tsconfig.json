{
  "compilerOptions": {
    "module": "nodenext",
    "target": "esnext",
     "rootDir": "./src",
    "outDir": "./dist",

    "types": ["node"],

    "sourceMap": true,

    "strict": true,

    "verbatimModuleSyntax": false,

    "isolatedModules": true,

    "moduleDetection": "force",

    "skipLibCheck": true
  }
}